---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.jsx';
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}
const { title, description, canonical, ogImage = '/og-image.svg', schema } = Astro.props;
const url = canonical || Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={url} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://payslipgen.in${ogImage}`} />
  <meta property="og:site_name" content="PaySlipGen.in" />
  <meta property="og:locale" content="en_IN" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://payslipgen.in${ogImage}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8854442638413146" crossorigin="anonymous"></script>
  <script is:inline>
    (function() {
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <script type="application/ld+json" set:html={JSON.stringify(schema || {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Salary Slip Generator India",
    "url": "https://payslipgen.in",
    "description": "Free online salary slip generator for Indian companies with PF, ESI, HRA auto-calculation",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "INR" },
    "author": { "@type": "Organization", "name": "PaySlipGen.in" }
  })} />
</head>
<body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 antialiased transition-colors">
  <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 px-4 py-3">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <a href="/" class="font-bold text-indigo-600 dark:text-indigo-400 text-lg">PaySlipGen.in</a>
      <nav class="hidden md:flex gap-4 text-sm text-gray-600 dark:text-gray-400" aria-label="Main navigation">
        <a href="/generator" class="hover:text-indigo-600 dark:hover:text-indigo-400">Generator</a>
        <a href="/pf-calculator" class="hover:text-indigo-600 dark:hover:text-indigo-400">PF</a>
        <a href="/hra-exemption-calculator" class="hover:text-indigo-600 dark:hover:text-indigo-400">HRA</a>
        <a href="/gratuity-calculator" class="hover:text-indigo-600 dark:hover:text-indigo-400">Gratuity</a>
        <a href="/tax-regime-comparator" class="hover:text-indigo-600 dark:hover:text-indigo-400">Tax</a>
        <a href="/salary-offer-comparison" class="hover:text-indigo-600 dark:hover:text-indigo-400">Compare</a>
        <a href="/bulk-generator" class="hover:text-indigo-600 dark:hover:text-indigo-400">Bulk</a>
      </nav>
      <div class="flex items-center gap-2">
        <ThemeToggle client:load />
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="border-t border-gray-200 dark:border-gray-800 mt-16 py-8 text-center text-gray-400 text-sm">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-4 mb-4">
        <a href="/generator" class="hover:text-indigo-600 dark:hover:text-indigo-400">Salary Slip Generator</a>
        <a href="/pf-calculator" class="hover:text-indigo-600 dark:hover:text-indigo-400">PF Calculator</a>
        <a href="/hra-exemption-calculator" class="hover:text-indigo-600 dark:hover:text-indigo-400">HRA Calculator</a>
        <a href="/gratuity-calculator" class="hover:text-indigo-600 dark:hover:text-indigo-400">Gratuity Calculator</a>
        <a href="/tax-regime-comparator" class="hover:text-indigo-600 dark:hover:text-indigo-400">Tax Regime</a>
        <a href="/salary-offer-comparison" class="hover:text-indigo-600 dark:hover:text-indigo-400">Compare Offers</a>
        <a href="/bulk-generator" class="hover:text-indigo-600 dark:hover:text-indigo-400">Bulk Generator</a>
        <a href="/salary-components" class="hover:text-indigo-600 dark:hover:text-indigo-400">Salary Guide</a>
      </div>
      <p>Free Salary Slip Generator &middot; Made for Indian businesses &middot; No sign-up required</p>
    </div>
  </footer>
</body>
</html>
