---
import Base from '../layouts/Base.astro';
---

<Base
  title="Free Salary Slip Generator India - Create Payslip Online"
  description="Generate professional salary slips online for free. Calculates PF, ESI, HRA, Professional Tax automatically. Download as PDF instantly. No sign-up required."
  schema={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Free Salary Slip Generator India",
    "url": "https://payslipgen.in",
    "description": "Generate professional Indian salary slips online for free. Auto-calculates PF, ESI, HRA, Professional Tax. Download as PDF.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "INR" },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "ratingCount": "1250"
    }
  }}
>
  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
      Generate Professional<br />
      <span class="text-indigo-600">Salary Slips</span> in Seconds
    </h1>
    <p class="text-gray-500 text-lg mt-6 max-w-2xl mx-auto">
      Free online salary slip generator for Indian companies. Automatically calculates PF, ESI, HRA, and Professional Tax. Download as print-ready PDF.
    </p>
    <a href="/generator"
      class="inline-block mt-8 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors text-base shadow-sm">
      Open Generator &rarr;
    </a>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16 text-left">
      <article class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <div class="text-2xl mb-3" aria-hidden="true">&#128176;</div>
        <h2 class="font-semibold text-gray-900 mb-1">Auto Tax Calculations</h2>
        <p class="text-gray-500 text-sm">PF, ESI, HRA metro/non-metro, and Professional Tax calculated automatically based on current Indian rules.</p>
      </article>
      <article class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <div class="text-2xl mb-3" aria-hidden="true">&#128196;</div>
        <h2 class="font-semibold text-gray-900 mb-1">Print-Ready PDF</h2>
        <p class="text-gray-500 text-sm">Download a professional salary slip as PDF or print directly from your browser. No watermarks, no sign-up.</p>
      </article>
      <article class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <div class="text-2xl mb-3" aria-hidden="true">&#128274;</div>
        <h2 class="font-semibold text-gray-900 mb-1">100% Private</h2>
        <p class="text-gray-500 text-sm">Everything runs in your browser. No data is sent to any server. Your salary information stays on your device.</p>
      </article>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">How It Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center mx-auto mb-3 text-xl font-bold">1</div>
        <h3 class="font-semibold text-gray-900 mb-1">Enter Details</h3>
        <p class="text-gray-500 text-sm">Fill in company info, employee details, and annual CTC</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center mx-auto mb-3 text-xl font-bold">2</div>
        <h3 class="font-semibold text-gray-900 mb-1">Auto Calculate</h3>
        <p class="text-gray-500 text-sm">PF, ESI, HRA, and all components calculated instantly</p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center mx-auto mb-3 text-xl font-bold">3</div>
        <h3 class="font-semibold text-gray-900 mb-1">Download PDF</h3>
        <p class="text-gray-500 text-sm">Print or download your professional salary slip</p>
      </div>
    </div>
  </section>
</Base>
