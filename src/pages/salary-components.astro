import Base from '../layouts/Base.astro';
---

<Base
  title="Salary Components Explained - Basic, HRA, PF, ESI, Professional Tax | PaySlipGen"
  description="Complete guide to Indian salary components. Learn what Basic Salary, HRA, PF, ESI, Special Allowance, and Professional Tax mean and how they are calculated."
  schema={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Indian Salary Components Explained",
    "description": "Complete guide to Indian salary components including Basic Salary, HRA, PF, ESI, and Professional Tax.",
    "author": { "@type": "Organization", "name": "PaySlipGen.in" },
    "publisher": { "@type": "Organization", "name": "PaySlipGen.in" },
    "datePublished": "2026-05-30",
    "dateModified": "2026-05-30",
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://payslipgen.in/salary-components" }
  }}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">Salary Components</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-4">Indian Salary Components Explained</h1>
    <p class="text-gray-500 text-lg mb-8">Understanding every line item on your payslip</p>

    <div class="prose prose-gray max-w-none space-y-8">
      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Basic Salary</h2>
        <p class="text-gray-600 leading-relaxed">
          Basic salary is the core component of your compensation, typically 40-50% of your CTC (Cost to Company). It forms the foundation for calculating other components like PF, gratuity, and HRA. Basic salary is fully taxable and is the fixed amount you receive before any additions or deductions.
        </p>
        <p class="text-gray-600 leading-relaxed mt-2">
          Companies set basic salary as a percentage of CTC. A higher basic means higher PF contributions and gratuity, but also a higher take-home in some structures. Most Indian companies use 40% of CTC as basic for non-metro cities and up to 50% for metro locations.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">House Rent Allowance (HRA)</h2>
        <p class="text-gray-600 leading-relaxed">
          HRA is provided to employees to cover rental housing costs. The amount depends on whether you live in a metro or non-metro city:
        </p>
        <ul class="list-disc list-inside text-gray-600 mt-2 space-y-1">
          <li><strong>Metro cities</strong> (Delhi, Mumbai, Kolkata, Chennai): 50% of Basic salary</li>
          <li><strong>Non-metro cities</strong>: 40% of Basic salary</li>
        </ul>
        <p class="text-gray-600 leading-relaxed mt-2">
          HRA is partially or fully exempt from income tax under Section 10(13A) of the Income Tax Act, provided you pay rent and meet certain conditions. You can claim the minimum of: actual HRA received, 50%/40% of basic, or rent paid minus 10% of basic.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Provident Fund (PF)</h2>
        <p class="text-gray-600 leading-relaxed">
          Under the Employees' Provident Fund Organisation (EPFO), both employee and employer contribute 12% of basic salary (capped at ₹15,000 basic) to the employee's PF account. This is a retirement savings scheme.
        </p>
        <ul class="list-disc list-inside text-gray-600 mt-2 space-y-1">
          <li><strong>Employee contribution</strong>: 12% of basic (deducted from salary)</li>
          <li><strong>Employer contribution</strong>: 12% of basic (additional cost to company)</li>
          <li>Maximum basic for PF calculation: ₹15,000/month</li>
          <li>PF earns interest (currently ~8.25% per annum) and is tax-exempt under Section 80C</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Employee State Insurance (ESI)</h2>
        <p class="text-gray-600 leading-relaxed">
          ESI is a self-financing social security scheme for employees earning up to ₹21,000/month. It provides medical, sickness, maternity, and disability benefits.
        </p>
        <ul class="list-disc list-inside text-gray-600 mt-2 space-y-1">
          <li><strong>Employee contribution</strong>: 0.75% of gross salary</li>
          <li><strong>Employer contribution</strong>: 3.25% of gross salary</li>
          <li>Only applicable if gross salary is ₹21,000 or less per month</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Conveyance Allowance</h2>
        <p class="text-gray-600 leading-relaxed">
          Conveyance allowance covers travel expenses from home to workplace and back. Under current IT rules, ₹1,600/month (₹19,200/year) is tax-exempt for salaried employees who do not receive a company vehicle. This is a standard fixed amount regardless of actual travel.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Medical Allowance</h2>
        <p class="text-gray-600 leading-relaxed">
          Medical allowance covers outpatient medical expenses. Up to ₹1,250/month (₹15,000/year) is tax-exempt under Section 17(2) of the Income Tax Act, provided you submit medical bills. Many companies provide this as a fixed component without requiring bills up to the exemption limit.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Special Allowance</h2>
        <p class="text-gray-600 leading-relaxed">
          Special allowance (also called flexible benefit plan or special payment) is the remainder amount after all other salary components are calculated. It is fully taxable and serves as a balancing figure to arrive at the total CTC. This component has no fixed formula and varies by company.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Professional Tax</h2>
        <p class="text-gray-600 leading-relaxed">
          Professional tax is a state-level tax levied on employed individuals. The maximum annual limit is ₹2,500 (₹200/month in most states). It varies by state - some states like Maharashtra have slabs based on income, while others charge a flat amount. It is deducted from salary and is eligible for tax deduction under Section 16(iii).
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">TDS (Tax Deducted at Source)</h2>
        <p class="text-gray-600 leading-relaxed">
          TDS is the income tax deducted by the employer based on your declared investments and applicable tax slab. If you have not submitted investment proofs, the employer may deduct higher TDS. You can adjust this while filing your ITR (Income Tax Return). TDS calculation considers your total annual income, applicable slab, and declared deductions under Sections 80C, 80D, HRA exemption, etc.
        </p>
      </section>

      <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-6 mt-8">
        <h3 class="font-semibold text-indigo-800 mb-2">Generate Your Salary Slip</h3>
        <p class="text-indigo-700 text-sm mb-3">Use our free calculator to see a detailed breakdown of all these components for your salary.</p>
        <a href="/generator" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-2 rounded-lg transition-colors text-sm">
          Open Generator &rarr;
        </a>
      </div>
    </div>
  </article>
</Base>
