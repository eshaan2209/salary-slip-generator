---
import Base from '../layouts/Base.astro';
import PFCalculator from '../components/PFCalculator.jsx';
---

<Base
  title="PF Calculator India - Calculate Provident Fund Online Free | PaySlipGen"
  description="Free online PF calculator for Indian employees. Calculate employee and employer provident fund contributions based on EPFO rules. 12% of basic, capped at ₹15,000."
  schema={{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "PF Calculator India - Calculate Provident Fund Contributions",
    "description": "Free online PF calculator. Calculate employee and employer provident fund contributions as per EPFO rules.",
    "author": { "@type": "Organization", "name": "PaySlipGen.in" },
    "publisher": { "@type": "Organization", "name": "PaySlipGen.in" },
    "datePublished": "2026-05-30",
    "dateModified": "2026-05-30",
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://payslipgen.in/pf-calculator" }
  }}
>
  <article class="max-w-2xl mx-auto px-4 py-12">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600">PF Calculator</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">PF Calculator</h1>
    <p class="text-gray-500 text-lg mb-8">Calculate your Provident Fund contributions as per EPFO rules</p>

    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm mb-8">
      <PFCalculator client:load />
    </div>

    <div class="prose prose-gray max-w-none space-y-6">
      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">What is PF (Provident Fund)?</h2>
        <p class="text-gray-600 leading-relaxed">
          Provident Fund is a retirement savings scheme managed by the Employees' Provident Fund Organisation (EPFO). Both employee and employer contribute 12% of the employee's basic salary (capped at ₹15,000/month basic) to the EPF account.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">How is PF Calculated?</h2>
        <ul class="list-disc list-inside text-gray-600 space-y-2">
          <li><strong>Employee contribution</strong>: 12% of basic salary (deducted from salary)</li>
          <li><strong>Employer contribution</strong>: 12% of basic salary (additional cost to company)</li>
          <li><strong>Basic cap</strong>: ₹15,000/month — if basic exceeds this, PF is calculated on ₹15,000 only</li>
          <li><strong>Voluntary PF</strong>: Employees can voluntarily contribute more through VPF</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-gray-900 mb-3">Tax Benefits</h2>
        <p class="text-gray-600 leading-relaxed">
          Employee PF contribution is eligible for tax deduction under Section 80C (up to ₹1.5 lakh annually). The interest earned on PF (currently ~8.25% p.a.) is also tax-exempt. PF amount is fully tax-free at the time of withdrawal after 5 years of continuous service.
        </p>
      </section>
    </div>

    <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-6 mt-8">
      <h3 class="font-semibold text-indigo-800 mb-2">Generate Full Salary Slip</h3>
      <p class="text-indigo-700 text-sm mb-3">See PF along with all other salary components in a professional salary slip.</p>
      <a href="/generator" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-2 rounded-lg transition-colors text-sm">
        Open Generator &rarr;
      </a>
    </div>
  </article>
</Base>
